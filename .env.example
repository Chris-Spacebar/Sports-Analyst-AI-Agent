# ---- Agent (optional, enables AI-written deep analysis) ----
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---- Mode: analysis | semi_auto | auto ----
# analysis  = research + probabilities only (default, safest)
# semi_auto = prepares orders, every order requires your click
# auto      = executes within guardrails (requires EXECUTION_ENABLED=true)
AGENT_MODE=analysis
EXECUTION_ENABLED=false

# ---- Kalshi (US-regulated, requires KYC account) ----
# Market data is public. Trading requires API credentials.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# ---- Polymarket (USDC on Polygon) ----
# Market data is public via the Gamma API. Trading requires CLOB API creds
# derived from your wallet. NEVER commit a private key.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# ---- Hyperliquid (HIP-4 event markets) ----
# Use a dedicated API wallet with limited permissions, never your main key.
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_API_WALLET_KEY=

# ---- Cron protection (set the same value in Vercel env) ----
CRON_SECRET=
